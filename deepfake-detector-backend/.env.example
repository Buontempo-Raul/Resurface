# API Settings
API_TITLE=Deepfake Detection API
API_VERSION=1.0.0
API_DESCRIPTION=AI-powered deepfake image detection service

# Server Settings
HOST=0.0.0.0
PORT=8000
DEBUG=True

# CORS Settings (comma-separated list)
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# File Upload Settings
MAX_FILE_SIZE=10485760  # 10MB in bytes
# ALLOWED_EXTENSIONS=.jpg,.jpeg,.png
# ALLOWED_MIME_TYPES=image/jpeg,image/png

# Detection Settings
USE_MOCK_DETECTOR=True  # Set to False to use EfficientNet model
MODEL_PATH=models/efficientnet_deepfake.pth
MODEL_VERSION=EfficientNet-B0 (FaceForensics++ C23)

# EfficientNet Settings
EFFICIENTNET_MODEL=efficientnet_b0
EFFICIENTNET_THRESHOLD=0.5

# Processing Settings
INFERENCE_TIMEOUT=30
BATCH_SIZE=1

# Rate Limiting
RATE_LIMIT=60
